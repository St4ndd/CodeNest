{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeNest",
  "version": "0.2.0",
  "identifier": "com.johanneshehl.codenest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeNest",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5RUY2NzZCM0NDODFCRkMKUldUOEc4ZzhhMmZ2S2NkWnRXMkh2WCtQSjdrUmhBcnBOUHVXV3dFeGsxOHlleFltOWJmKy9FY0EK",
      "endpoints": [
        "https://github.com/St4ndd/CodeNest/releases/latest/download/latest.json"
      ]
    }
  }
}
