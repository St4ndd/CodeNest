{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeNest",
  "version": "0.1.0",
  "identifier": "com.johanneshehl.codenest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeNest",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 620,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
